{
  "name": "TerminalState",
  "type": "object",
  "properties": {
    "session_id": {
      "type": "string",
      "default": "main",
      "description": "Session identifier"
    },
    "fase_atual": {
      "type": "number",
      "default": 1
    },
    "acertos": {
      "type": "number",
      "default": 0
    },
    "erros": {
      "type": "number",
      "default": 0
    },
    "screen_lines": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Current lines displayed on screen"
    },
    "phase_text": {
      "type": "string",
      "default": "",
      "description": "Current phase question/text being displayed"
    },
    "current_input": {
      "type": "string",
      "default": ""
    },
    "is_loading_bar": {
      "type": "boolean",
      "default": false
    },
    "loading_duration": {
      "type": "number",
      "default": 60
    },
    "show_final_message": {
      "type": "boolean",
      "default": false
    },
    "is_typing": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "session_id"
  ]
}
